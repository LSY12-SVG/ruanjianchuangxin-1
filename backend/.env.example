IMAGE_TO_3D_PROVIDER=mock
IMAGE_TO_3D_PORT=3001
IMAGE_TO_3D_DB_PATH=backend/data/image-to-3d.db
IMAGE_TO_3D_MAX_UPLOAD_BYTES=6291456
IMAGE_TO_3D_POLL_AFTER_MS=5000
IMAGE_TO_3D_MAX_POLL_MS=600000
IMAGE_TO_3D_RESULT_TTL_MS=86400000
IMAGE_TO_3D_RATE_LIMIT_WINDOW_MS=60000
IMAGE_TO_3D_RATE_LIMIT_MAX=20
MOCK_3D_MODEL_URL=https://modelviewer.dev/shared-assets/models/Astronaut.glb

# Set IMAGE_TO_3D_PROVIDER=tencent after Tencent Cloud AI3D is enabled.
TENCENT_REGION=ap-guangzhou
TENCENT_HUNYUAN_3D_MODEL=3.0
TENCENT_HUNYUAN_3D_VARIANT=rapid
TENCENT_SECRET_ID=
