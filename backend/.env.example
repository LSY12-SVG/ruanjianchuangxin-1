PORT=8787
MODEL_PROVIDER=openai_compat
MODEL_BASE_URL=https://api.siliconflow.cn/v1
MODEL_PRIMARY_NAME=Qwen/Qwen2.5-VL-32B-Instruct
MODEL_FALLBACK_NAME=Pro/Qwen/Qwen2.5-VL-7B-Instruct
MODEL_FAST_NAME=Pro/Qwen/Qwen2.5-VL-7B-Instruct
MODEL_REFINE_NAME=Qwen/Qwen2.5-VL-32B-Instruct
MODEL_TIMEOUT_MS=30000
MODEL_NAME=Qwen/Qwen2.5-VL-32B-Instruct
MODEL_API_KEY=replace_me
# Voice refine strict mode:
# false -> prefer availability (allow backend fallback output)
# true  -> strict real-model only
COLOR_VOICE_STRICT_MODE=false

# Cloud ASR (voice-transcribe)
ASR_PROVIDER=openai_compat
ASR_BASE_URL=https://api.siliconflow.cn/v1
ASR_API_KEY=replace_me
ASR_MODEL=FunAudioLLM/SenseVoiceSmall
ASR_TIMEOUT_MS=30000
ASR_MAX_UPLOAD_BYTES=8388608

# Cloud route SLO budgets (ms) to avoid long-tail blocking on mobile.
INTERPRET_FAST_TIMEOUT_MS=2600
INTERPRET_FAST_BUDGET_MS=3600
INTERPRET_VOICE_TIMEOUT_MS=4500
INTERPRET_VOICE_BUDGET_MS=8000

# Auto-grade phase budgets (ms). Keep refine in quality-first range.
AUTOGRADE_FAST_TIMEOUT_MS=5000
AUTOGRADE_FAST_BUDGET_MS=5500
AUTOGRADE_REFINE_TIMEOUT_MS=50000
AUTOGRADE_REFINE_BUDGET_MS=50000

JWT_SECRET=replace_me_with_strong_secret
JWT_EXPIRES_IN=7d
SQLITE_DB_PATH=./data/app.db
# Debug only: allow full feature usage without login token
# AUTH_BYPASS=true
# AUTH_BYPASS_USER_ID=1
# AUTH_BYPASS_USERNAME=debug_user_1

# Community module uses JWT from account module.
# Read endpoints are public; write endpoints require Bearer token.
COMMUNITY_ENABLE=true
DB_CLIENT=sqlite
SQLITE_PATH=./data/community.sqlite
DB_SSL=false
COMMUNITY_PAGE_SIZE_DEFAULT=10
COMMUNITY_PAGE_SIZE_MAX=30

# Agent runtime memory persistence
AGENT_MEMORY_PATH=./data/agent-memory.json

# 2D -> 3D backend module
IMAGE_TO_3D_PROVIDER=tripo
IMAGE_TO_3D_PUBLIC_BASE_URL=
# IMAGE_TO_3D_DB_PATH=backend/data/image-to-3d.db
# IMAGE_TO_3D_CAPTURE_DIR=backend/data/capture-frames
IMAGE_TO_3D_MAX_UPLOAD_BYTES=10485760
IMAGE_TO_3D_POLL_AFTER_MS=5000
IMAGE_TO_3D_MAX_POLL_MS=600000
IMAGE_TO_3D_RESULT_TTL_MS=86400000
IMAGE_TO_3D_RATE_LIMIT_WINDOW_MS=60000
IMAGE_TO_3D_RATE_LIMIT_MAX=20
# Strict startup precheck requires valid Tripo credentials.
TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi
TRIPO_SECRET_KEY=replace-with-your-tripo-secret-key
TRIPO_MODEL_VERSION=v3.0-20250812
TRIPO_OUTPUT_FORMAT=glb
TRIPO_TEXTURE=true
TRIPO_PBR=false

# Optional Tencent provider.
TENCENT_REGION=ap-guangzhou
TENCENT_HUNYUAN_3D_MODEL=3.0
TENCENT_HUNYUAN_3D_VARIANT=rapid
TENCENT_SECRET_ID=replace-with-your-tencent-secret-id
TENCENT_SECRET_KEY=replace-with-your-tencent-secret-key
