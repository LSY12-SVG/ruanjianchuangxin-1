PORT=8787
MODEL_PROVIDER=openai_compat
MODEL_BASE_URL=https://api.siliconflow.cn/v1
MODEL_PRIMARY_NAME=Qwen/Qwen2.5-VL-32B-Instruct
MODEL_FALLBACK_NAME=Pro/Qwen/Qwen2.5-VL-7B-Instruct
MODEL_FAST_NAME=Pro/Qwen/Qwen2.5-VL-7B-Instruct
MODEL_REFINE_NAME=Qwen/Qwen2.5-VL-32B-Instruct
MODEL_TIMEOUT_MS=30000
MODEL_NAME=Qwen/Qwen2.5-VL-32B-Instruct
MODEL_API_KEY=replace_me

# Cloud route SLO budgets (ms) to avoid long-tail blocking on mobile.
INTERPRET_FAST_TIMEOUT_MS=2600
INTERPRET_FAST_BUDGET_MS=3600
INTERPRET_VOICE_TIMEOUT_MS=4500
INTERPRET_VOICE_BUDGET_MS=8000

# Auto-grade phase budgets (ms). Keep refine in quality-first range.
AUTOGRADE_FAST_TIMEOUT_MS=5000
AUTOGRADE_FAST_BUDGET_MS=5500
AUTOGRADE_REFINE_TIMEOUT_MS=50000
AUTOGRADE_REFINE_BUDGET_MS=50000

JWT_SECRET=replace_me_with_strong_secret
JWT_EXPIRES_IN=7d
SQLITE_DB_PATH=./data/app.db
# Debug only: allow full feature usage without login token
# AUTH_BYPASS=true
# AUTH_BYPASS_USER_ID=1
# AUTH_BYPASS_USERNAME=debug_user_1

# Community module uses JWT from account module.
# Read endpoints are public; write endpoints require Bearer token.
COMMUNITY_ENABLE=true
DB_CLIENT=sqlite
SQLITE_PATH=./data/community.sqlite
DB_SSL=false
COMMUNITY_PAGE_SIZE_DEFAULT=10
COMMUNITY_PAGE_SIZE_MAX=30

# Agent runtime memory persistence
AGENT_MEMORY_PATH=./data/agent-memory.json
